@model web_phong_kham_tu_nhan.Models.Entities.LichHen

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/BenhNhanHome/Reschedule.css"/>
<div class="reschedule-page">
    <div class="container">
        <div class="reschedule-wrap">
            <a asp-area="BenhNhan" asp-controller="LichHen" asp-action="Detail"
               asp-route-id="@Model.Id" class="rs-back">
                <i class="bi bi-arrow-left"></i> Quay lại chi tiết
            </a>

            <div class="rs-card">
                <div class="rs-header">
                    <h4><i class="bi bi-arrow-repeat me-2"></i>Đổi lịch hẹn</h4>
                    <p>Mã lịch: #LH-@Model.Id.ToString("D4") &nbsp;·&nbsp; BS. @Model.BacSi?.FullName</p>
                </div>

                <div class="rs-body">

                    <!-- LỊCH HIỆN TẠI -->
                    <div class="current-info">
                        <h6><i class="bi bi-clock-history me-1"></i> Lịch hiện tại</h6>
                        <div class="current-row">
                            <i class="bi bi-calendar-event"></i>
                            <span>Ngày: <s>@Model.AppointmentDate.ToString("dd/MM/yyyy")</s></span>
                        </div>
                        <div class="current-row">
                            <i class="bi bi-clock"></i>
                            <span>Giờ: <s>@Model.TimeSlot</s></span>
                        </div>
                    </div>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" style="border-radius:10px;font-size:14px">
                            <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                        </div>
                    }

                    <form asp-area="BenhNhan" asp-controller="LichHen" asp-action="Reschedule"
                          asp-route-id="@Model.Id" method="post" id="rsForm">
                        @Html.AntiForgeryToken()

                        <!-- NGÀY MỚI -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-calendar3 me-1" style="color:#0d6efd "></i> Chọn ngày mới
                            </label>
                            <div class="date-input-wrap">
                                <i class="bi bi-calendar-event"></i>
                                <input type="date" name="appointmentDate" id="newDate" class="form-control form-control-lg"
                                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       onchange="loadSlots()" required />
                            </div>
                        </div>

                        <!-- GIỜ MỚI -->
                        <div class="mb-4" id="slotWrap" style="display:none">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-clock me-1" style="color:#0d6efd"></i> Chọn khung giờ mới
                            </label>
                            <div class="timeslot-grid" id="slotGrid"></div>
                            <input type="hidden" name="timeSlot" id="hSlot" required />
                        </div>

                        <!-- LÝ DO -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-chat-text me-1" style="color:#0d6efd"></i> Lý do khám
                                <span class="text-muted fw-normal">(không bắt buộc)</span>
                            </label>
                            <textarea name="lyDoKham" class="form-control" rows="3"
                                      placeholder="Cập nhật lý do khám nếu có thay đổi...">@Model.LyDoKham</textarea>
                        </div>

                        <div class="d-flex gap-3 flex-wrap pt-2" style="border-top:1px solid #f1f5f9;">
                            <a asp-area="BenhNhan" asp-controller="LichHen" asp-action="Detail"
                               asp-route-id="@Model.Id"
                               class="btn btn-outline-secondary px-4 d-inline-flex align-items-center" style="border-radius:8px;">
                                <i class="bi bi-x me-1"></i> Hủy bỏ
                            </a>
                            <button type="submit" class="btn-save" id="btnSave" disabled>
                                <i class="bi bi-check-circle"></i> Lưu lịch mới
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const ALL_SLOTS = [
        '07:30 - 08:00','08:00 - 08:30','08:30 - 09:00','09:00 - 09:30',
        '09:30 - 10:00','10:00 - 10:30','10:30 - 11:00','11:00 - 11:30',
        '13:00 - 13:30','13:30 - 14:00','14:00 - 14:30','14:30 - 15:00',
        '15:00 - 15:30','15:30 - 16:00','16:00 - 16:30','16:30 - 17:00'
    ];

    function loadSlots() {
        const date = document.getElementById('newDate').value;
        if (!date) return;
        const wrap = document.getElementById('slotWrap');
        const grid = document.getElementById('slotGrid');
        document.getElementById('hSlot').value = '';
        document.getElementById('btnSave').disabled = true;
        wrap.style.display = 'block';
        grid.innerHTML = `<div class="text-muted py-2" style="grid-column:1/-1"><span class="spinner-border spinner-border-sm me-2" style="color:#f59e0b"></span>Đang tải...</div>`;

        fetch(`/BenhNhan/LichHen/GetBookedSlots?doctorId=@Model.BacSiId&date=${date}`)
            .then(r => r.json())
            .then(booked => {
                grid.innerHTML = '';
                ALL_SLOTS.forEach(slot => {
                    const isBooked = booked.includes(slot);
                    grid.innerHTML += `<button type="button" class="timeslot-btn ${isBooked?'booked':''}" data-slot="${slot}"
                        onclick="${isBooked?'':'selectSlot(this)'}" ${isBooked?'disabled':''}>${slot}</button>`;
                });
            });
    }

    function selectSlot(el) {
        document.querySelectorAll('.timeslot-btn').forEach(b => b.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('hSlot').value = el.dataset.slot;
        document.getElementById('btnSave').disabled = false;
    }
</script>
@model web_phong_kham_tu_nhan.Models.Entities.LichHen

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    string TrangThaiLabel(int tt) => tt switch { 0=>"Chờ xác nhận", 1=>"Đã xác nhận", 2=>"Hoàn thành", 3=>"Đã hủy", _=>"Không xác định" };
    string TrangThaiColor(int tt) => tt switch { 0=>"#f59e0b", 1=>"#0d6efd", 2=>"#10b981", 3=>"#94a3b8", _=>"#94a3b8" };
    string TrangThaiIcon(int tt)  => tt switch { 0=>"bi-hourglass-split", 1=>"bi-calendar-check", 2=>"bi-patch-check-fill", 3=>"bi-x-circle", _=>"bi-question" };
}
<link rel="stylesheet" href="~/css/BenhNhanHome/Detail.css" />
<div class="detail-page">
    <div class="container">
        <div class="detail-wrap">
            <a asp-area="BenhNhan" asp-controller="LichHen" asp-action="MyAppointment" class="detail-back">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>

            <div class="detail-card">

                <div class="detail-card-top">
                    <div>
                        <h4><i class="bi bi-calendar2-check me-2"></i>Chi tiết lịch hẹn</h4>
                        <p>Mã lịch hẹn: #LH-@Model.Id.ToString("D4") &nbsp;·&nbsp; Đặt ngày @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="status-pill" style="background:rgba(255,255,255,.15)">
                        <i class="bi @TrangThaiIcon(Model.TrangThai)"></i>
                        @TrangThaiLabel(Model.TrangThai)
                    </div>
                </div>

                <div class="detail-body">

                    <!-- BÁC SĨ -->
                    <div class="doctor-block">
                        <img src="@(Model.BacSi?.ImageUrl ?? "/Images/default-avatar.png")"
                             onerror="this.src='/Images/default-avatar.png'"
                             alt="@Model.BacSi?.FullName" />
                        <div class="doctor-block-info">
                            <h5>@Model.BacSi?.FullName</h5>
                            <span>@Model.ChuyenKhoa?.Name</span>
                            <p>@Model.BacSi?.tieuSu</p>
                        </div>
                    </div>

                    <!-- THÔNG TIN -->
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-item-label"><i class="bi bi-calendar-event"></i> Ngày khám</div>
                            <div class="info-item-value">@Model.AppointmentDate.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="info-item">
                            <div class="info-item-label"><i class="bi bi-clock"></i> Khung giờ</div>
                            <div class="info-item-value">@Model.TimeSlot</div>
                        </div>
                        <div class="info-item">
                            <div class="info-item-label"><i class="bi bi-hospital"></i> Chuyên khoa</div>
                            <div class="info-item-value">@Model.ChuyenKhoa?.Name</div>
                        </div>
                        <div class="info-item">
                            <div class="info-item-label"><i class="bi bi-activity"></i> Trạng thái</div>
                            <div class="info-item-value" style="color:@TrangThaiColor(Model.TrangThai)">@TrangThaiLabel(Model.TrangThai)</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.LyDoKham))
                    {
                        <div class="lydo-block">
                            <label><i class="bi bi-chat-text-fill"></i> Lý do khám</label>
                            <p>@Model.LyDoKham</p>
                        </div>
                    }

                    <!-- ACTIONS -->
                    <div class="detail-actions">
                        <a asp-area="BenhNhan" asp-controller="LichHen" asp-action="MyAppointment"
                           class="btn-act-outline">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>

                        @if (Model.TrangThai == 0 || Model.TrangThai == 1)
                        {
                            <a asp-area="BenhNhan" asp-controller="LichHen" asp-action="Reschedule"
                               asp-route-id="@Model.Id" class="btn-act-warn">
                                <i class="bi bi-arrow-repeat"></i> Đổi lịch
                            </a>

                            <form asp-area="BenhNhan" asp-controller="LichHen" asp-action="Cancel"
                                  method="post" style="display:inline"
                                  onsubmit="return confirm('Bạn có chắc muốn hủy lịch hẹn này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn-act-danger">
                                    <i class="bi bi-x-circle"></i> Hủy lịch
                                </button>
                            </form>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
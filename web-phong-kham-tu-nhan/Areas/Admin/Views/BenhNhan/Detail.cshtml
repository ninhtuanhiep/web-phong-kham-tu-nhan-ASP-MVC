@model web_phong_kham_tu_nhan.Models.Entities.BenhNhan

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết bệnh nhân";
    string activeTab = TempData["ActiveTab"] as string ?? "view";
    var lichHens = Model.LichHens ?? new List<web_phong_kham_tu_nhan.Models.Entities.LichHen>();
    string ttClass = Model.TrangThai == 1 ? "active" : "inactive";
    string ttLabel = Model.TrangThai == 1 ? "Hoạt động" : "Không hoạt động";
    string initials = "";
    if (!string.IsNullOrEmpty(Model.FullName))
    {
        var parts = Model.FullName.Split(' ');
        initials = parts.Length > 1
            ? (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper()
            : parts[0][0].ToString().ToUpper();
    }
}

<link rel="stylesheet" href="~/css/Admin/BenhNhan/Detail.css">
<div class="container" style="padding:35px">
    <a asp-area="Admin" asp-controller="BenhNhan" asp-action="Index" class="back-link">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>

    <div class="hero">
        <div class="hero-av">@initials</div>
        <div style="flex:1">
            <div class="hero-name">@(Model.FullName ?? "—")</div>
            <div class="hero-sub">
                @(Model.GioiTinh ?? "")
                @(Model.NgaySinh.HasValue ? " · " + Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "")
            </div>
            <div class="hero-badges">
                <span class="hero-badge @ttClass">
                    <i class="bi @(Model.TrangThai == 1 ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                    @ttLabel
                </span>
                @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                {
                    <span class="hero-badge"><i class="bi bi-telephone-fill"></i> @Model.PhoneNumber</span>
                }
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <span class="hero-badge"><i class="bi bi-envelope-fill"></i> @Model.Email</span>
                }
            </div>
        </div>
        <div style="font-size:13px;opacity:.7;align-self:flex-start">#BN-@Model.Id.ToString("D4")</div>
    </div>

    <!-- STATS -->
    <div class="stats-row">
        <div class="stat-box blue">
            <div class="stat-num">@lichHens.Count</div>
            <div class="stat-lbl">Tổng lịch hẹn</div>
        </div>
        <div class="stat-box green">
            <div class="stat-num">@lichHens.Count(l => l.TrangThai == 2)</div>
            <div class="stat-lbl">Đã hoàn thành</div>
        </div>
        <div class="stat-box amber">
            <div class="stat-num">@lichHens.Count(l => l.TrangThai == 0 || l.TrangThai == 1)</div>
            <div class="stat-lbl">Đang chờ / xác nhận</div>
        </div>
    </div>

    <!-- ACTION BAR -->
    <div class="action-bar">
        <button class="btn-act btn-edit-act" onclick="switchTab('edit',null)">
            <i class="bi bi-pencil-square"></i> Chỉnh sửa
        </button>
        <form asp-area="Admin" asp-controller="BenhNhan" asp-action="ResetMatKhau"
              method="post" style="display:inline"
              onsubmit="return confirm('Reset mật khẩu cho @Model.FullName?')">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn-act btn-reset-act">
                <i class="bi bi-key"></i> Reset mật khẩu
            </button>
        </form>
        <form asp-area="Admin" asp-controller="BenhNhan" asp-action="Delete"
              method="post" style="display:inline"
              onsubmit="return confirm('Vô hiệu hóa tài khoản @Model.FullName?')">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn-act btn-del-act">
                <i class="bi bi-person-slash"></i> Vô hiệu hóa
            </button>
        </form>
    </div>

    <!-- TABS -->
    <div class="tab-nav">
        <button class="tab-btn @(activeTab == "view" ? "active" : "")"
                id="tbView" onclick="switchTab('view',this)">
            <i class="bi bi-person-badge-fill"></i>
            <span>Thông tin</span>
        </button>
        <button class="tab-btn @(activeTab == "edit" ? "active" : "")"
                id="tbEdit" onclick="switchTab('edit',this)">
            <i class="bi bi-pencil-square"></i>
            <span>Chỉnh sửa</span>
        </button>
        <button class="tab-btn @(activeTab == "appt" ? "active" : "")"
                id="tbAppt" onclick="switchTab('appt',this)">
            <i class="bi bi-calendar2-check"></i>
            <span>Lịch hẹn (@lichHens.Count)</span>
        </button>
    </div>

    <!-- ═══ TAB VIEW ═══ -->
    <div class="tab-panel @(activeTab == "view" ? "active" : "")" id="tab-view">
        <div class="d-card">
            <div class="d-card-hd">
                <i class="bi bi-person-fill"></i>
                <h5>Thông tin cá nhân</h5>
            </div>
            <div class="d-card-bd">
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-lbl"><i class="bi bi-person"></i> Họ và tên</div>
                        <div class="info-val @(string.IsNullOrEmpty(Model.FullName) ? "empty" : "")">
                            @(Model.FullName ?? "Chưa cập nhật")
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-lbl"><i class="bi bi-gender-ambiguous"></i> Giới tính</div>
                        <div class="info-val @(string.IsNullOrEmpty(Model.GioiTinh) ? "empty" : "")">
                            @(Model.GioiTinh ?? "Chưa cập nhật")
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-lbl"><i class="bi bi-cake2"></i> Ngày sinh</div>
                        <div class="info-val @(Model.NgaySinh == null ? "empty" : "")">
                            @(Model.NgaySinh.HasValue? Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-lbl"><i class="bi bi-envelope"></i> Email</div>
                        <div class="info-val @(string.IsNullOrEmpty(Model.Email) ? "empty" : "")">
                            @(Model.Email ?? "Chưa cập nhật")
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-lbl"><i class="bi bi-telephone"></i> Số điện thoại</div>
                        <div class="info-val @(string.IsNullOrEmpty(Model.PhoneNumber) ? "empty" : "")">
                            @(Model.PhoneNumber ?? "Chưa cập nhật")
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-lbl"><i class="bi bi-activity"></i> Trạng thái</div>
                        <div class="info-val">
                            <span class="tt-pill @(Model.TrangThai == 1 ? "tt-2" : "tt-3")">
                                @(Model.TrangThai == 1 ? "Hoạt động" : "Không hoạt động")
                            </span>
                        </div>
                    </div>
                    <div class="info-item info-full">
                        <div class="info-lbl"><i class="bi bi-geo-alt"></i> Địa chỉ</div>
                        <div class="info-val @(string.IsNullOrEmpty(Model.DiaChi) ? "empty" : "")">
                            @(Model.DiaChi ?? "Chưa cập nhật")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-card">
            <div class="d-card-hd">
                <i class="bi bi-clipboard2-heart-fill"></i>
                <h5>Lịch sử y tế</h5>
            </div>
            <div class="d-card-bd">
                @if (!string.IsNullOrEmpty(Model.LichSuYTe))
                {
                    <div style="background:#fffbeb;border-radius:10px;padding:14px 18px;
                                border-left:4px solid #f59e0b;font-size:14px;
                                color:#78350f;line-height:1.7;white-space:pre-line">
                        @Model.LichSuYTe
                    </div>
                }
                else
                {
                    <div class="empty-appt">
                        <i class="bi bi-clipboard2"></i>
                        <p>Chưa có thông tin lịch sử y tế.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ═══ TAB EDIT ═══ -->
    <div class="tab-panel @(activeTab == "edit" ? "active" : "")" id="tab-edit">
        <div class="d-card">
            <div class="d-card-hd">
                <i class="bi bi-pencil-square"></i>
                <h5>Chỉnh sửa thông tin bệnh nhân</h5>
            </div>
            <div class="d-card-bd">
                <form asp-area="Admin" asp-controller="BenhNhan" asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="form-grid">
                        <div class="fg form-full">
                            <label><i class="bi bi-person"></i> Họ và tên</label>
                            <input type="text" name="fullName" class="fc"
                                   value="@Model.FullName" placeholder="Nhập họ và tên" required />
                        </div>
                        <div class="fg">
                            <label><i class="bi bi-envelope"></i> Email</label>
                            <input type="email" name="email" class="fc"
                                   value="@Model.Email" placeholder="abc@email.com" />
                        </div>
                        <div class="fg">
                            <label><i class="bi bi-telephone"></i> Số điện thoại</label>
                            <input type="tel" name="phoneNumber" class="fc"
                                   value="@Model.PhoneNumber" placeholder="0912 345 678" />
                        </div>
                        <div class="fg">
                            <label><i class="bi bi-cake2"></i> Ngày sinh</label>
                            <input type="date" name="ngaySinh" class="fc"
                                   value="@(Model.NgaySinh.HasValue? Model.NgaySinh.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>
                        <div class="fg">
                            <label><i class="bi bi-gender-ambiguous"></i> Giới tính</label>
                            <select name="gioiTinh" class="fc">
                                <option value="">-- Chọn --</option>
                                <option value="Nam" selected="@(Model.GioiTinh == "Nam" ? "selected" : "")">Nam</option>
                                <option value="Nữ" selected="@(Model.GioiTinh == "Nữ" ? "selected" : "")">Nữ</option>
                                <option value="Khác" selected="@(Model.GioiTinh == "Khác" ? "selected" : "")">Khác</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label><i class="bi bi-activity"></i> Trạng thái</label>
                            <select name="trangThai" class="fc">
                                <option value="1" selected="@(Model.TrangThai == 1 ? "selected" : "")">Hoạt động</option>
                                <option value="0" selected="@(Model.TrangThai == 0 ? "selected" : "")">Không hoạt động</option>
                            </select>
                        </div>
                        <div class="fg form-full">
                            <label><i class="bi bi-geo-alt"></i> Địa chỉ</label>
                            <input type="text" name="diaChi" class="fc"
                                   value="@Model.DiaChi" placeholder="Số nhà, đường, phường, quận, tỉnh" />
                        </div>
                        <div class="fg form-full">
                            <label><i class="bi bi-clipboard2-heart"></i> Lịch sử y tế</label>
                            <textarea name="lichSuYTe" class="fc" rows="4"
                                      placeholder="Tiền sử bệnh lý, dị ứng thuốc, bệnh nền...">@Model.LichSuYTe</textarea>
                        </div>
                    </div>
                    <div class="save-bar">
                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-circle"></i> Lưu thay đổi
                        </button>
                        <button type="button" class="btn-cancel-f" onclick="switchTab('view',null)">
                            Hủy bỏ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ═══ TAB LỊCH HẸN ═══ -->
    <div class="tab-panel @(activeTab == "appt" ? "active" : "")" id="tab-appt">
        <div class="d-card">
            <div class="d-card-hd">
                <i class="bi bi-calendar2-check-fill"></i>
                <h5>Lịch sử lịch hẹn</h5>
            </div>
            <div class="d-card-bd" style="padding:0">
                @if (!lichHens.Any())
                {
                    <div class="empty-appt">
                        <i class="bi bi-calendar-x"></i>
                        <p>Chưa có lịch hẹn nào.</p>
                    </div>
                }
                else
                {
                    <table class="appt-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ngày khám</th>
                                <th>Giờ</th>
                                <th>Bác sĩ</th>
                                <th>Lý do</th>
                                <th>Trạng thái</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lh in lichHens.OrderByDescending(l => l.AppointmentDate))
                            {
                                string[] ttLabels = { "Chờ xác nhận", "Đã xác nhận", "Hoàn thành", "Đã hủy" };
                                string[] ttClasses = { "tt-0", "tt-1", "tt-2", "tt-3" };
                                int idx = Math.Min(lh.TrangThai, 3);
                                <tr>
                                    <td style="color:#94a3b8">#@lh.Id</td>
                                    <td style="font-weight:600">@lh.AppointmentDate.ToString("dd/MM/yyyy")</td>
                                    <td>@(lh.TimeSlot ?? "—")</td>
                                    <td>@(lh.BacSi?.FullName ?? "—")</td>
                                    <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                        title="@lh.LyDoKham">
                                        @(lh.LyDoKham ?? "—")
                                    </td>
                                    <td>
                                        <span class="tt-pill @ttClasses[idx]">@ttLabels[idx]</span>
                                    </td>
                                    <td>
                                        <a asp-area="Admin" asp-controller="LichHen"
                                           asp-action="Detail" asp-route-id="@lh.Id"
                                           style="font-size:12px;color:#0d6efd;text-decoration:none;
                                                      font-weight:600">
                                            Xem →
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>

<script>
    function switchTab(name, el) {
        document.querySelectorAll('.tab-panel').forEach(function(p){ p.classList.remove('active'); });
        document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
        document.getElementById('tab-' + name).classList.add('active');
        var btnMap = { view:'tbView', edit:'tbEdit', appt:'tbAppt' };
        var btn = document.getElementById(btnMap[name]);
        if (btn) btn.classList.add('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>
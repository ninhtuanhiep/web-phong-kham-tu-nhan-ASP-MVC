<div class="patient-details-container">

    <div class="patient-details-card">

        <div class="patient-header">
            <h2>Chi tiết bệnh nhân</h2>

            <span class="status-badge @(Model.TrangThai == 1 ? " status-active" : "status-inactive") ">
                Trạng thái: @(Model.TrangThai == 1 ? "Đang nằm viện" : "Đã xuất viện")
            </span>
        </div>


        <!-- Personal Information -->
        <div class="detail-section">

            <div class="section-title">
                👤 Thông tin cá nhân
            </div>

            <div class="detail-box">
                <div class="detail-grid">

                    <div>
                        <div class="detail-label">Họ tên</div>
                        <div class="detail-value">@Model.FullName</div>
                    </div>

                    <div>
                        <div class="detail-label">Giới tính</div>
                        <div class="detail-value">@Model.GioiTinh</div>
                    </div>

                    <div>
                        <div class="detail-label">Ngày sinh</div>
                        <div class="detail-value">@Model.NgaySinh</div>
                    </div>

                </div>
            </div>

        </div>


        <!-- Contact -->
        <div class="detail-section">

            <div class="section-title">
                📞 Thông tin liên hệ
            </div>

            <div class="detail-box">
                <div class="detail-grid">

                    <div>
                        <div class="detail-label">Email</div>
                        <div class="detail-value">@Model.Email</div>
                    </div>

                    <div>
                        <div class="detail-label">Số điện thoại</div>
                        <div class="detail-value">@Model.PhoneNumber</div>
                    </div>

                    <div>
                        <div class="detail-label">Địa chỉ</div>
                        <div class="detail-value">@Model.DiaChi</div>
                    </div>

                </div>
            </div>

        </div>

    <!-- Medical History -->
    <div class="detail-section">
            <div class="section-title">
                🏥 Lịch sử y tế
            </div>
            <div class="detail-box">
                <p>@Model.LichSuYTe</p>
            </div>
            <br />

        <a asp-action="Index" class="btn btn-secondary btn-back">
            ← Quay lại
        </a>

    </div>

</div>
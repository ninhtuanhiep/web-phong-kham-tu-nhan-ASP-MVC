@model web_phong_kham_tu_nhan.Models.Entities.User

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="bi bi-person-vcard"></i> Thông tin chi tiết người dùng
            </h4>
        </div>

        <div class="card-body">

            <div class="row" style="display:flex; align-items:center;">

                <!-- Avatar -->
                <div class="col-md-4 text-center">

                    <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png"
                         class="rounded-circle mb-3"
                         width="200" />

                    <h5>@Model.FullName</h5>

                    <p class="text-muted">@Model.Email</p>

                </div>

                <!-- Thông tin -->
                <div class="col-md-8">

                    <table class="table table-bordered">

                        <tr>
                            <th style="width:200px;">ID</th>
                            <td>@Model.Id</td>
                        </tr>

                        <tr>
                            <th>Họ và tên</th>
                            <td>@Model.FullName</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>
                        <tr>
                            <th>Password</th>
                            <td>

                                <div class="input-group" style="max-width:1000px;">

                                    <span id="passwordText" class="form-control">••••••••</span>

                                    <span id="realPassword" class="form-control" style="display:none;">
                                        @Model.Password
                                    </span>

                                    <button class="btn btn-outline-secondary"
                                            type="button"
                                            onclick="togglePassword()">

                                        <i id="eyeIcon" class="bi bi-eye"></i>

                                    </button>

                                </div>

                            </td>
                        </tr>

                        <tr>
                            <th>Số điện thoại</th>
                            <td>@Model.PhoneNumber</td>
                        </tr>

                        <tr>
                            <th>Vai trò</th>
                            <td>

                                @if (Model.Role == "Admin")
                                {
                                    <span class="badge role-admin">Admin</span>
                                }
                                else if (Model.Role == "Bác sĩ")
                                {
                                    <span class="badge role-bacsi">Bác sĩ</span>
                                }
                                else
                                {
                                    <span class="badge role-benhnhan">Bệnh nhân</span>
                                }

                            </td>
                        </tr>

                        <tr>
                            <th>Trạng thái</th>
                            <td>

                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã khóa</span>
                                }

                            </td>
                        </tr>

                        <tr>
                            <th>Ngày tạo</th>
                            <td>@Model.CreateAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>

                    </table>

                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-end">

                <a asp-action="Index" class="btn btn-secondary me-2">
                    Quay lại
                </a>
            </div>

        </div>

    </div>

</div>

<script>

    function togglePassword() {

        var text = document.getElementById("passwordText");
        var real = document.getElementById("realPassword");
        var icon = document.getElementById("eyeIcon");

        if (real.style.display === "none") {

            real.style.display = "inline";
            text.style.display = "none";

            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");

        }
        else {

            real.style.display = "none";
            text.style.display = "inline";

            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");

        }

    }

</script>
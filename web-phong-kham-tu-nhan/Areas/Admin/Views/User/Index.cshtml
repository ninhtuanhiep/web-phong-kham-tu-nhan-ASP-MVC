@using X.PagedList.Mvc.Core
@using X.PagedList
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model X.PagedList.IPagedList<web_phong_kham_tu_nhan.Models.Entities.User>

<div class="main-content">
    <div class="page-header">
        <h1>QUẢN LÝ NGƯỜI DÙNG</h1>
        <p>Quản lý người dùng của hệ thống</p>
    </div>

    <div class="row mb-4">
        @{
            var role = Context.Request.Query["role"].ToString();
        }
        <div class="col-md-3">
            <a asp-action="Index" class="text-decoration-none">
                <div class="card stat-card @(string.IsNullOrEmpty(role) ? "active" : "")">
                    <div class="card-body">
                        <p>TẤT CẢ NGƯỜI DÙNG</p>
                        <h3 style="color:aqua;">@ViewBag.AllUser</h3>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="Index" asp-route-role="Admin" class="text-decoration-none">
                <div class="card stat-card @(role == "Admin" ? "active" : "")">
                    <div class="card-body">
                        <p>ADMIN</p>
                        <h3>@ViewBag.Admin</h3>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="Index" asp-route-role="Bác sĩ" class="text-decoration-none">
                <div class="card stat-card @(role == "Bác sĩ" ? "active" : "")">
                    <div class="card-body">
                        <p>BÁC SĨ</p>
                        <h3>@ViewBag.BacSi</h3>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-action="Index" asp-route-role="Bệnh nhân" class="text-decoration-none">
                <div class="card stat-card @(role == "Bệnh nhân" ? "active" : "")">
                    <div class="card-body">
                        <p>BỆNH NHÂN</p>
                        <h3>@ViewBag.BenhNhan</h3>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="card-box">
        <div class="card-header">
            <h5>Tất cả người dùng</h5>
            <div class="header-actions">
                <input type="search" id="searchInput" placeholder="Nhập người dùng cần tìm" class="form-control search-box" />
                <a asp-action="Create" class="btn btn-primary">Thêm người dùng mới</a>
            </div>
        </div>

        <table id="UserTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td class="fw-bold">@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.PhoneNumber</td>
                            <td>
                                <span class="role-badge @(item.Role == "Admin" ? "role-admin" : item.Role == "Bác sĩ" ? "role-bacsi" : "role-benhnhan")">
                                    @item.Role
                                </span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="status-badge status-active">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Đã khóa</span>
                                }
                            </td>
                            <td>@item.CreateAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">👁</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">✏</a>

                                @* ✅ ToggleStatus: POST form thay vì GET link *@
                                @if (item.IsActive)
                                {
                                    <form asp-area="Admin" asp-controller="User" asp-action="ToggleStatus"
                                          asp-route-id="@item.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('Khóa tài khoản @item.FullName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger me-1" title="Khóa tài khoản">
                                            <i class="bi bi-lock"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-area="Admin" asp-controller="User" asp-action="ToggleStatus"
                                          asp-route-id="@item.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('Kích hoạt tài khoản @item.FullName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success me-1" title="Kích hoạt tài khoản">
                                            <i class="bi bi-unlock"></i>
                                        </button>
                                    </form>
                                }

                                @* ✅ Delete: POST form thay vì GET link *@
                                @if (item.Role != "Admin")
                                {
                                    <form asp-area="Admin" asp-controller="User" asp-action="Delete"
                                          asp-route-id="@item.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('Xóa vĩnh viễn tài khoản @item.FullName? Hành động không thể hoàn tác.')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger btn-delete" title="Xóa">🗑</button>
                                    </form>
                                }
                                else
                                {
                                    @* Không cho xóa Admin *@
                                    <button type="button" class="btn btn-sm btn-secondary btn-delete"
                                            title="Không thể xóa tài khoản Admin" disabled>
                                        🗑
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            Không có dữ liệu người dùng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @Html.PagedListPager(Model, page => Url.Action("Index", new { page, role }))
        <p class="text-muted text-center mt-2">
            Hiển thị @Model.FirstItemOnPage - @Model.LastItemOnPage trong tổng số @Model.TotalItemCount người dùng
        </p>
    </div>
</div>

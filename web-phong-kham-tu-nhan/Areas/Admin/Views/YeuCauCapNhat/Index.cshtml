@model List<web_phong_kham_tu_nhan.Models.Entities.YeuCauCapNhat>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Yêu cầu cập nhật hồ sơ";
    string trangThai = ViewBag.TrangThai as string ?? "0";
    int tongCho = (int)(ViewBag.TongChoduyet ?? 0);
    int tongDuyet = (int)(ViewBag.TongDaDuyet ?? 0);
    int tongTuChoi = (int)(ViewBag.TongTuchoi ?? 0);

    // Map tên field sang tên hiển thị
    var fieldNames = new Dictionary<string, string> {
        {"HocVi","Học vị"}, {"HocHam","Học hàm"}, {"SoCCHN","Số CCHN"},
        {"PhamViHanhNghe","Phạm vi HN"}, {"KinhNghiem","Kinh nghiệm"},
        {"TruongDaoTao","Trường đào tạo"}, {"ChuyenMonSau","Chuyên môn sâu"},
        {"GiaiThuong","Giải thưởng"}, {"NgonNgu","Ngôn ngữ"},
        {"NamKinhNghiem","Số năm KN"}
    };
    string tenHienThi(string key) => fieldNames.ContainsKey(key) ? fieldNames[key] : key;
}

<link rel="stylesheet" href="~/css/Admin/YeuCauCapNhat/Index.css"/>
<div class="container">
    <div class="page-hd">
        <h1>YÊU CẦU CẬP NHẬT HỒ SƠ</h1>
        @*
        <div class="notification-container" id="toastContainer">
            @if (TempData["Success"] != null)
            {
                <div class="custom-toast success" id="successToast">
                    <span class="toast-icon"><i class="bi bi-check-circle-fill"></i></span>
                    <div class="toast-content">
                        <div class="toast-title">Thành công</div>
                        <div class="toast-msg">@TempData["Success"]</div>
                    </div>
                    <button class="toast-close" onclick="closeToast('successToast')">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="custom-toast error" id="errorToast">
                    <span class="toast-icon"><i class="bi bi-x-circle-fill"></i></span>
                    <div class="toast-content">
                        <div class="toast-title">Lỗi</div>
                        <div class="toast-msg">@TempData["Error"]</div>
                    </div>
                    <button class="toast-close" onclick="closeToast('errorToast')">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
        </div> *@
    </div>
   
    <!-- STATS -->
    <div class="stat-row">
        <a href="@Url.Action("Index", new { trangThai = "0" })"
           class="stat-box cho @(trangThai == "0" ? "ring-2 ring-amber-400" : "")">
            <div class="stat-icon si-amber"><i class="bi bi-hourglass-split"></i></div>
            <div><div class="stat-num">@tongCho</div><div class="stat-lbl">Chờ duyệt</div></div>
        </a>
        <a href="@Url.Action("Index", new { trangThai = "1" })"
           class="stat-box duyet">
            <div class="stat-icon si-green"><i class="bi bi-check-circle-fill"></i></div>
            <div><div class="stat-num">@tongDuyet</div><div class="stat-lbl">Đã duyệt</div></div>
        </a>
        <a href="@Url.Action("Index", new { trangThai = "2" })"
           class="stat-box tuchoi">
            <div class="stat-icon si-red"><i class="bi bi-x-circle-fill"></i></div>
            <div><div class="stat-num">@tongTuChoi</div><div class="stat-lbl">Đã từ chối</div></div>
        </a>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <a href="@Url.Action("Index", new { trangThai = "all" })"
           class="filter-tab @(trangThai == "all" ? "active" : "")">
            Tất cả <span class="ms-1">@Model.Count</span>
        </a>
        <a href="@Url.Action("Index", new { trangThai = "0" })"
           class="filter-tab @(trangThai == "0" ? "active" : "")">
            <i class="bi bi-hourglass-split"></i> Chờ duyệt
        </a>
        <a href="@Url.Action("Index", new { trangThai = "1" })"
           class="filter-tab @(trangThai == "1" ? "active" : "")">
            <i class="bi bi-check-circle"></i> Đã duyệt
        </a>
        <a href="@Url.Action("Index", new { trangThai = "2" })"
           class="filter-tab @(trangThai == "2" ? "active" : "")">
            <i class="bi bi-x-circle"></i> Từ chối
        </a>

        <form method="get" style="display:flex;align-items:center;gap:8px;flex:1;min-width:200px">
            <input type="hidden" name="trangThai" value="@trangThai" />
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@ViewBag.Search"
                       placeholder="Tìm theo tên bác sĩ..." />
            </div>
        </form>
    </div>

    <!-- BULK ACTION BAR -->
    @if (trangThai == "0")
    {
        <div class="bulk-bar" id="bulkBar">
            <span id="bulkCount">0 yêu cầu được chọn</span>
            <form asp-area="Admin" asp-controller="YeuCauCapNhat" asp-action="DuyetNhieu"
                  method="post" id="bulkForm">
                @Html.AntiForgeryToken()
                <div id="bulkIds"></div>
                <button type="submit" class="btn btn-success btn-sm px-4" style="border-radius:8px"
                        onclick="return confirm('Duyệt tất cả yêu cầu đã chọn?')">
                    <i class="bi bi-check-all me-1"></i> Duyệt tất cả đã chọn
                </button>
            </form>
        </div>
    }

    <!-- DANH SÁCH -->
    @if (!Model.Any())
    {
        <div class="empty-box">
            <i class="bi bi-inbox"></i>
            <h5>Không có yêu cầu nào</h5>
            <p class="text-muted" style="font-size:14px">
                @(trangThai == "0" ? "Hiện không có yêu cầu nào đang chờ duyệt." : "Không tìm thấy kết quả phù hợp.")
            </p>
        </div>
    }
    else
    {
        @foreach (var yc in Model)
        {
            string ttBadge = yc.TrangThai == 0 ? "badge-cho"
            : yc.TrangThai == 1 ? "badge-duyet" : "badge-tuchoi";
            string ttLabel = yc.TrangThai == 0 ? "Chờ duyệt"
            : yc.TrangThai == 1 ? "Đã duyệt" : "Từ chối";
            string ttIcon = yc.TrangThai == 0 ? "bi-hourglass-split"
            : yc.TrangThai == 1 ? "bi-check-circle-fill" : "bi-x-circle-fill";
            string tenBacSi = yc.BacSi?.FullName ?? "Không rõ";
            string imgUrl = yc.BacSi?.ImageUrl ?? "/Images/default-avatar.png";
            string fieldName = tenHienThi(yc.TenTruong);

            <div class="yc-card @(yc.TrangThai == 0 ? "cho-duyet" : "")" id="yc-@yc.Id"
                 onclick="openModal(@yc.Id,'@tenBacSi','@imgUrl','@fieldName',
                             '@Html.Raw((yc.GiaTriCu ?? "").Replace("'", "&#39;").Replace("\n", " "))',
                             '@Html.Raw((yc.GiaTriMoi ?? "").Replace("'", "&#39;").Replace("\n", " "))',
                             '@Html.Raw((yc.LyDo ?? "").Replace("'", "&#39;"))',
                             @yc.TrangThai,
                             '@Html.Raw((yc.LyDoTuChoi ?? "").Replace("'", "&#39;"))')">
                <div class="yc-body">

                    @if (trangThai == "0")
                    {
                        <div class="yc-check" onclick="event.stopPropagation()">
                            <input type="checkbox" class="yc-checkbox" data-id="@yc.Id"
                                   onchange="updateBulk()" />
                        </div>
                    }
                    else
                    {
                        <div></div>
                    }

                    <div class="yc-info">
                        <div class="yc-doctor">
                            <img src="@imgUrl" onerror="this.src='/Images/default-avatar.png'" alt="" />
                            BS. @tenBacSi
                        </div>
                        <div class="yc-meta">
                            <span class="field-pill">
                                <i class="bi bi-tag-fill" style="font-size:10px"></i> @fieldName
                            </span>
                            <span class="yc-meta-item">
                                <i class="bi bi-clock"></i> @yc.TaoLuc.ToString("dd/MM/yyyy HH:mm")
                            </span>
                            @if (yc.DuyetLuc.HasValue)
                            {
                                <span class="yc-meta-item">
                                    <i class="bi bi-person-check"></i>
                                    Duyệt bởi @yc.DuyetBoi lúc @yc.DuyetLuc.Value.ToString("dd/MM HH:mm")
                                </span>
                            }
                        </div>
                        <div class="yc-change">
                            @if (!string.IsNullOrEmpty(yc.GiaTriCu))
                            {
                                <span class="yc-old">@(yc.GiaTriCu.Length > 50 ? yc.GiaTriCu.Substring(0, 50) + "..." : yc.GiaTriCu)</span>
                                <i class="bi bi-arrow-right" style="font-size:11px;color:#94a3b8"></i>
                            }
                            <span class="yc-new">@(yc.GiaTriMoi.Length > 60 ? yc.GiaTriMoi.Substring(0, 60) + "..." : yc.GiaTriMoi)</span>
                        </div>
                        @if (!string.IsNullOrEmpty(yc.LyDo))
                        {
                            <div class="yc-lydo">
                                <i class="bi bi-chat-text-fill" style="font-size:11px"></i>
                                @yc.LyDo
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(yc.LyDoTuChoi))
                        {
                            <div class="yc-lydo" style="background:#fef2f2;color:#991b1b">
                                <i class="bi bi-x-circle-fill" style="font-size:11px"></i>
                                @yc.LyDoTuChoi
                            </div>
                        }
                    </div>

                    <div class="yc-actions" onclick="event.stopPropagation()">
                        <span class="status-pill @ttBadge">
                            <i class="bi @ttIcon"></i> @ttLabel
                        </span>
                        @if (yc.TrangThai == 0)
                        {
                            <button class="btn-duyet" onclick="openModal(@yc.Id,'@tenBacSi','@imgUrl','@fieldName',
                                            '@Html.Raw((yc.GiaTriCu ?? string.Empty).Replace("'", "&#39;"))',
                                            '@Html.Raw(yc.GiaTriMoi.Replace("'", "&#39;"))',
                                            '@Html.Raw((yc.LyDo ?? string.Empty).Replace("'", "&#39;"))',
                                            0,'')">
                                <i class="bi bi-eye"></i> Xem & Duyệt
                            </button>
                        }
                        else
                        {
                            <form asp-area="Admin" asp-controller="YeuCauCapNhat" asp-action="Xoa"
                                  method="post" onsubmit="return confirm('Xóa yêu cầu này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@yc.Id" />
                                <button type="submit" class="btn-xoa-sm">
                                    <i class="bi bi-trash3"></i> Xóa
                                </button>
                            </form>
                        }
                    </div>

                </div>
            </div>
        }
    }
</div>

<!-- MODAL XEM & DUYỆT -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
    <div class="modal-box">
        <div class="modal-hd" id="modalHd" style="background:linear-gradient(135deg,#f59e0b,#fbbf24)">
            <h5><i class="bi bi-file-earmark-text me-2"></i>Chi tiết yêu cầu cập nhật</h5>
            <button class="modal-cl" onclick="closeModalBtn()"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-bd">

            <!-- Bác sĩ -->
            <div class="modal-section" style="display:flex;align-items:center;gap:12px">
                <img id="m-img" src="" style="width:48px;height:48px;border-radius:50%;
                     object-fit:cover;object-position:top;border:2px solid #dbeafe" />
                <div>
                    <div style="font-weight:700;font-size:15px;color:#1e293b" id="m-bacsi"></div>
                    <div style="font-size:12px;color:#0d6efd;font-weight:600" id="m-field"></div>
                </div>
            </div>

            <!-- Thay đổi -->
            <div class="modal-section">
                <div class="modal-lbl">Giá trị cũ</div>
                <div class="modal-val" id="m-cu" style="color:#94a3b8;text-decoration:line-through">—</div>
                <div class="modal-lbl mt-2">Giá trị mới đề xuất</div>
                <div class="modal-val" id="m-moi" style="color:#0d6efd"></div>
            </div>

            <!-- Lý do -->
            <div class="modal-section" id="m-lydo-block" style="display:none">
                <div class="modal-lbl">Lý do / Giải thích</div>
                <div class="modal-val" id="m-lydo" style="color:#78350f;background:#fef9c3;
                     border-radius:6px;padding:8px;font-size:13px"></div>
            </div>

            <!-- Lý do từ chối (chỉ hiện khi đã xử lý) -->
            <div id="m-tuchoi-block" style="display:none">
                <div class="modal-section" style="background:#fef2f2;border-color:#fecaca">
                    <div class="modal-lbl" style="color:#991b1b">Lý do từ chối</div>
                    <div class="modal-val" id="m-tuchoi" style="color:#dc2626;font-size:13px"></div>
                </div>
            </div>

            <!-- Form từ chối (nhập lý do) -->
            <div id="m-tuchoi-form" style="display:none">
                <label style="font-size:12px;font-weight:600;color:#475569;margin-bottom:5px;display:block">
                    <i class="bi bi-x-circle text-danger me-1"></i> Lý do từ chối <span style="color:#ef4444">*</span>
                </label>
                <textarea id="m-lydo-tuchoi" class="form-control" rows="2"
                          placeholder="Nhập lý do từ chối để thông báo cho bác sĩ..."
                          style="border-radius:8px;font-size:13px;border:1.5px solid #e2e8f0;width:100%;padding:8px 12px;margin-bottom:12px"></textarea>
            </div>

            <!-- Actions -->
            <div class="modal-actions" id="m-actions">
                <form id="formDuyet" asp-area="Admin" asp-controller="YeuCauCapNhat"
                      asp-action="Duyet" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="m-id" />
                    <input type="hidden" name="chapNhan" value="true" />
                    <button type="submit" class="btn-confirm-duyet">
                        <i class="bi bi-check-circle-fill"></i> Duyệt & Áp dụng
                    </button>
                </form>
                <button type="button" class="btn-confirm-tuchoi" onclick="toggleTuChoi()">
                    <i class="bi bi-x-circle"></i> <span id="btnTuChoiText">Từ chối</span>
                </button>
            </div>

            <!-- Form submit từ chối ẩn -->
            <form id="formTuChoi" asp-area="Admin" asp-controller="YeuCauCapNhat"
                  asp-action="Duyet" method="post" style="display:none">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="m-id2" />
                <input type="hidden" name="chapNhan" value="false" />
                <input type="hidden" name="lyDoTuChoi" id="m-lydo-submit" />
                <button type="submit" id="btnSubmitTuChoi"
                        style="display:none"></button>
            </form>

        </div>
    </div>
</div>

<script>
    var tuChoiMode = false;

    function openModal(id, bacsi, img, field, cu, moi, lydo, trangThai, lyDoTuChoi) {
        document.getElementById('m-id').value  = id;
        document.getElementById('m-id2').value = id;
        document.getElementById('m-bacsi').textContent = 'BS. ' + bacsi;
        document.getElementById('m-field').textContent = field;
        document.getElementById('m-img').src = img;
        document.getElementById('m-cu').textContent  = cu  || '(Chưa có)';
        document.getElementById('m-moi').textContent = moi || '—';

        var lydoBlock = document.getElementById('m-lydo-block');
        if (lydo && lydo.trim()) {
            document.getElementById('m-lydo').textContent = lydo;
            lydoBlock.style.display = 'block';
        } else {
            lydoBlock.style.display = 'none';
        }

        // Ẩn form từ chối
        tuChoiMode = false;
        document.getElementById('m-tuchoi-form').style.display = 'none';
        document.getElementById('m-lydo-tuchoi').value = '';
        document.getElementById('btnTuChoiText').textContent = 'Từ chối';

        // Nếu đã xử lý thì ẩn actions
        var actions = document.getElementById('m-actions');
        var tuChoiHienThi = document.getElementById('m-tuchoi-block');
        if (trangThai === 0) {
            actions.style.display = 'flex';
            tuChoiHienThi.style.display = 'none';
            document.getElementById('modalHd').style.background = 'linear-gradient(135deg,#f59e0b,#fbbf24)';
        } else if (trangThai === 1) {
            actions.style.display = 'none';
            tuChoiHienThi.style.display = 'none';
            document.getElementById('modalHd').style.background = 'linear-gradient(135deg,#10b981,#34d399)';
        } else {
            actions.style.display = 'none';
            document.getElementById('m-tuchoi').textContent = lyDoTuChoi || '—';
            tuChoiHienThi.style.display = 'block';
            document.getElementById('modalHd').style.background = 'linear-gradient(135deg,#ef4444,#f87171)';
        }

        document.getElementById('modalOverlay').classList.add('show');
    }

    function toggleTuChoi() {
        tuChoiMode = !tuChoiMode;
        document.getElementById('m-tuchoi-form').style.display = tuChoiMode ? 'block' : 'none';
        document.getElementById('btnTuChoiText').textContent   = tuChoiMode ? 'Xác nhận từ chối' : 'Từ chối';

        if (tuChoiMode) {
            // Submit form từ chối khi bấm lần 2
            document.querySelector('.btn-confirm-tuchoi').onclick = function() {
                var lydo = document.getElementById('m-lydo-tuchoi').value.trim();
                if (!lydo) { alert('Vui lòng nhập lý do từ chối.'); return; }
                document.getElementById('m-lydo-submit').value = lydo;
                document.getElementById('btnSubmitTuChoi').click();
            };
        } else {
            document.querySelector('.btn-confirm-tuchoi').onclick = toggleTuChoi;
        }
    }

    function closeModal(e) {
        if (e.target === document.getElementById('modalOverlay'))
            document.getElementById('modalOverlay').classList.remove('show');
    }
    function closeModalBtn() {
        document.getElementById('modalOverlay').classList.remove('show');
    }

    // BULK SELECT
    function updateBulk() {
        var checked = document.querySelectorAll('.yc-checkbox:checked');
        var bar     = document.getElementById('bulkBar');
        var count   = document.getElementById('bulkCount');
        var ids     = document.getElementById('bulkIds');

        if (checked.length > 0) {
            bar.classList.add('show');
            count.textContent = checked.length + ' yêu cầu được chọn';
            ids.innerHTML = '';
            checked.forEach(function(cb) {
                ids.innerHTML += '<input type="hidden" name="ids" value="' + cb.dataset.id + '" />';
            });
        } else {
            bar.classList.remove('show');
        }

        // Highlight card
        document.querySelectorAll('.yc-card').forEach(function(card){ card.classList.remove('selected'); });
        checked.forEach(function(cb) {
            document.getElementById('yc-' + cb.dataset.id)?.classList.add('selected');
        });
    }

    function closeToast() {
        var toast = document.getElementById('successToast');
        if (toast) {
            toast.classList.add('toast-out');
            setTimeout(function(){ toast.remove(); }, 500);
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        var toast = document.getElementById('successToast');
        if (toast) setTimeout(closeToast, 2000);
    });
</script>

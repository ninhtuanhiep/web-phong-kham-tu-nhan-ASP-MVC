@model List<web_phong_kham_tu_nhan.Models.Entities.LichLamViecBacSi>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Lịch làm việc";
    DateTime startOfWeek = (DateTime)ViewBag.StartOfWeek;
    DateTime endOfWeek = (DateTime)ViewBag.EndOfWeek;
    var doctor = ViewBag.Doctor as web_phong_kham_tu_nhan.Models.Entities.BacSi;
    string[] tenThu = { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
    string[] tenThuFull = { "Chủ nhật", "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7" };
}
<link rel="stylesheet" href="~/css/BacSiHome/LichLamViec.css" />
<div class="llv-page">
    <div class="container">
        <div class="notification-container" id="toastContainer">
            @if (TempData["Success"] != null)
            {
                <div class="custom-toast success" id="successToast">
                    <span class="toast-icon"><i class="bi bi-check-circle-fill"></i></span>
                    <div class="toast-content">
                        <div class="toast-title">Thành công</div>
                        <div class="toast-msg">@TempData["Success"]</div>
                    </div>
                    <button class="toast-close" onclick="closeToast('successToast')">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="custom-toast error" id="errorToast">
                    <span class="toast-icon"><i class="bi bi-x-circle-fill"></i></span>
                    <div class="toast-content">
                        <div class="toast-title">Lỗi</div>
                        <div class="toast-msg">@TempData["Error"]</div>
                    </div>
                    <button class="toast-close" onclick="closeToast('errorToast')">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
        </div>
        <a asp-area="BacSi" asp-controller="Profile" asp-action="Index" class="detail-back">
            <i class="bi bi-arrow-left"></i> Quay lại trang thông tin
        </a>

        <!-- HEADER -->
        <div class="llv-header">
            <div>
                <h2><i class="bi bi-calendar3 me-2"></i>Lịch làm việc của tôi</h2>
                <p>Xem lịch, đăng ký ca làm và gửi đơn xin nghỉ</p>
            </div>
            @if (doctor != null)
            {
                <div class="doctor-pill">
                    <img src="@(doctor.ImageUrl ?? "/Images/default-avatar.png")"
                         onerror="this.src='/Images/default-avatar.png'" />
                    <span>BS. @doctor.FullName</span>
                </div>
            }
        </div>

        <!-- STATS -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon" style="background:#eff6ff;color:#0d6efd"><i class="bi bi-calendar-check"></i></div>
                <div><div class="stat-num">@ViewBag.NgayLamThang</div><div class="stat-lbl">Ngày làm tháng này</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#fffbeb;color:#f59e0b"><i class="bi bi-calendar-x"></i></div>
                <div><div class="stat-num">@ViewBag.NgayNghiThang</div><div class="stat-lbl">Ngày nghỉ tháng này</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#fef9c3;color:#d97706"><i class="bi bi-hourglass-split"></i></div>
                <div><div class="stat-num">@ViewBag.DonChoDuyet</div><div class="stat-lbl">Đơn chờ duyệt</div></div>
            </div>
        </div>

        <!-- FORM ĐĂNG KÝ CA LÀM -->
        <div class="register-card">
            <h6><i class="bi bi-calendar-plus text-primary"></i>Đăng ký ca làm việc</h6>
            <form asp-area="BacSi" asp-controller="LichLamViec" asp-action="DangKyCa" method="post">
                @Html.AntiForgeryToken()
                <div class="reg-grid">
                    <div class="form-group">
                        <label><i class="bi bi-calendar-event me-1"></i>Từ ngày</label>
                        <input type="date" name="ngayBatDau" class="form-control form-control-sm"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="form-group">
                        <label><i class="bi bi-calendar-event me-1"></i>Đến ngày</label>
                        <input type="date" name="ngayKetThuc" class="form-control form-control-sm"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="form-group">
                        <label><i class="bi bi-sun me-1"></i>Ca làm</label>
                        <select name="ca" class="form-select form-select-sm">
                            <option value="Sang">Sáng</option>
                            <option value="Chieu">Chiều</option>
                            <option value="CaNgay">Cả ngày</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label><i class="bi bi-people me-1"></i>Tối đa BN</label>
                        <input type="number" name="soBenhNhanToiDa" class="form-control form-control-sm"
                               value="20" min="1" max="100" />
                    </div>
                    <div class="form-group" style="grid-column:1/4">
                        <label><i class="bi bi-chat-text me-1"></i>Ghi chú</label>
                        <input type="text" name="ghiChu" class="form-control form-control-sm"
                               placeholder="Ghi chú thêm (không bắt buộc)" />
                    </div>
                    <div>
                        <button type="submit" class="btn-reg w-100">
                            <i class="bi bi-plus-circle"></i>Đăng ký
                        </button>
                    </div>
                </div>
            </form>
            <div class="mt-2" style="font-size:12px;color:#94a3b8">
                <i class="bi bi-info-circle me-1"></i>
                Ca làm đăng ký sẽ hiển thị ngay. Admin có thể chỉnh sửa hoặc xóa nếu cần.
            </div>
        </div>

        <!-- NAV TUẦN -->
        <div class="week-nav">
            <a href="@Url.Action("Index", new { tuan = startOfWeek.AddDays(-7).ToString("yyyy-MM-dd") })" class="btn-nav">
                <i class="bi bi-chevron-left"></i>
            </a>
            <div>
                <div class="week-label">@startOfWeek.ToString("dd/MM") — @endOfWeek.ToString("dd/MM/yyyy")</div>
                @if (startOfWeek <= DateTime.Today && DateTime.Today <= endOfWeek)
                {
                    <small class="badge bg-primary" style="font-size:10px">Tuần này</small>
                }
            </div>
            <div style="display:flex;align-items:center;gap:6px">
                <a href="@Url.Action("Index", new { tuan = DateTime.Today.ToString("yyyy-MM-dd") })"
                   class="btn btn-outline-primary btn-sm" style="border-radius:7px;font-size:12px">
                    <i class="bi bi-calendar-day me-1"></i>Tuần này
                </a>
                <a href="@Url.Action("Index", new { tuan = startOfWeek.AddDays(7).ToString("yyyy-MM-dd") })" class="btn-nav">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>

        <!-- LEGEND -->
        <div class="legend">
            <div class="legend-item"><div class="legend-dot" style="background:#eff6ff;border:1.5px solid #0d6efd"></div>Làm việc</div>
            <div class="legend-item"><div class="legend-dot" style="background:#fffbeb;border:1.5px solid #f59e0b"></div>Nghỉ phép</div>
            <div class="legend-item"><div class="legend-dot" style="background:#fef2f2;border:1.5px solid #ef4444"></div>Nghỉ bệnh</div>
            <div class="legend-item"><div class="legend-dot" style="background:#fef9c3;border:1.5px solid #eab308"></div>Chờ duyệt nghỉ</div>
        </div>
        

        <!-- BẢNG LỊCH TUẦN -->
        <div class="week-table">

            <table>
                <thead>
                    <tr>
                        <th>Ca</th>
                        @for (int i = 0; i < 7; i++)
                        {
                            DateTime ngay = startOfWeek.AddDays(i);
                            bool isToday = ngay.Date == DateTime.Today;
                            <th class="@(isToday ? "today-col" : "")">
                                <div class="th-date @(isToday ? "today" : "")">@ngay.Day</div>
                                <div style="font-size:10px;color:#94a3b8">@tenThuFull[(int)ngay.DayOfWeek]</div>
                                @if (isToday)
                                {
                                    <small class="badge bg-primary" style="font-size:9px">Hôm nay</small>
                                }
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        string[] cacas = { "Sang", "Chieu", "CaNgay" };
                        string[] caLabels = { "Sáng", "Chiều", "Cả ngày" };
                    }
                    @for (int caIdx = 0; caIdx < cacas.Length; caIdx++)
                    {
                        string ca = cacas[caIdx];
                        <tr>
                            <td>@caLabels[caIdx]</td>
                            @for (int i = 0; i < 7; i++)
                            {
                                DateTime ngay = startOfWeek.AddDays(i);
                                bool isToday = ngay.Date == DateTime.Today;
                                bool isPast = ngay.Date < DateTime.Today;
                                var lichNgayCa = Model.Where(l => l.Ngay.Date == ngay.Date && l.CaLam == ca).ToList();
                                <td class="@(isToday ? "today-col" : "")">
                                    @if (!lichNgayCa.Any())
                                    {
                                        <div class="empty-cell">—</div>
                                    }
                                    else
                                    {
                                        foreach (var l in lichNgayCa)
                                        {
                                            string ttLabel = l.TrangThai == 0 ? "Làm việc"
                                            : l.TrangThai == 1 ? "Nghỉ phép"
                                            : l.TrangThai == 2 ? "Nghỉ bệnh"
                                            : "Chờ duyệt";
                                            <div class="lich-cell lich-cell-@l.TrangThai">
                                                <div class="cell-title">@ttLabel</div>
                                                <div class="cell-sub">
                                                    <i class="bi bi-people-fill"></i> @l.SoBenhNhanToiDa BN
                                                </div>

                                                @* GHI CHÚ *@
                                                @if (!string.IsNullOrEmpty(l.GhiChu))
                                                {
                                                    <div class="cell-note">
                                                        <i class="bi bi-sticky"></i> @l.GhiChu
                                                    </div>
                                                }

                                                @* NÚT XIN NGHỈ *@
                                                @if (l.TrangThai == 0 && !isPast)
                                                {
                                                    <button class="btn-xinngh" title="Xin nghỉ"
                                                            onclick="openModal(@l.Id, '@ngay.ToString("dd/MM/yyyy")', '@caLabels[caIdx]')">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                }

                                                @* NÚT HỦY ĐƠN *@
                                                @if (l.TrangThai == 3)
                                                {
                                                    <form asp-area="BacSi" asp-controller="LichLamViec"
                                                          asp-action="HuyDon" method="post" style="display:inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@l.Id" />
                                                        <button type="submit" class="btn-huyday" title="Hủy đơn">
                                                            <i class="bi bi-arrow-counterclockwise"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        }
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL XIN NGHỈ -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
    <div class="modal-box">
        <div class="modal-hd" style="background:linear-gradient(135deg,#ef4444,#f87171)">
            <h5><i class="bi bi-calendar-x me-2"></i>Gửi đơn xin nghỉ</h5>
            <button class="modal-cl" onclick="closeModalBtn()"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-bd">
            <div class="modal-info">
                <strong id="modalTitle">Thông tin ca</strong>
                <span id="modalSub" style="font-size:12px;color:#94a3b8">Chờ tải...</span>
            </div>
            <form asp-area="BacSi" asp-controller="LichLamViec" asp-action="XinNghi" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalLichId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:13px">
                        <i class="bi bi-chat-text text-danger me-1"></i>Lý do xin nghỉ
                    </label>
                    <textarea name="lyDo" class="form-control" rows="3"
                              placeholder="Nhập lý do xin nghỉ..."
                              style="border-radius:8px;font-size:13px"></textarea>
                </div>
                <div class="alert alert-warning d-flex align-items-center gap-2 mb-3"
                     style="border-radius:8px;font-size:12px">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Đơn chờ Admin xác nhận. Lịch hẹn trong ngày đó sẽ không bị ảnh hưởng cho đến khi được duyệt.
                </div>
                <button type="submit" class="btn-submit-nghi">
                    <i class="bi bi-send me-2"></i>Gửi đơn xin nghỉ
                </button>
            </form>
        </div>
    </div>
</div>

<script>
        function openModal(id, ngay, ca) {
        document.getElementById('modalLichId').value = id;
        document.getElementById('modalTitle').textContent = ca + ' — ngày ' + ngay;
        document.getElementById('modalOverlay').classList.add('show');
    }
    function closeModal(e) {
        if (e.target === document.getElementById('modalOverlay'))
            document.getElementById('modalOverlay').classList.remove('show');
    }
    function closeModalBtn() {
        document.getElementById('modalOverlay').classList.remove('show');
    }

     function closeToast(id) {
        const toast = document.getElementById(id);

        // Nếu không tìm thấy hoặc đã đang ẩn rồi thì bỏ qua
        if (!toast || toast.classList.contains('toast-out')) return;

        // Bắt đầu kích hoạt hiệu ứng ẩn bằng CSS
        toast.classList.add('toast-out');

        // Chờ hiệu ứng kết thúc hoàn toàn mới xóa khỏi DOM
        toast.addEventListener('transitionend', function handler(e) {
            // Chỉ xóa khi thuộc tính 'opacity' hoặc 'transform' hoàn tất
            if (e.propertyName === 'opacity' || e.propertyName === 'transform') {
                toast.remove();
            }
        }, { once: true });
    }

    document.addEventListener("DOMContentLoaded", function () {
        // Tự động đóng sau 4 giây (cho người dùng kịp đọc)
        const autoCloseIds = ['successToast', 'errorToast'];

        autoCloseIds.forEach(id => {
            const toast = document.getElementById(id);
            if (toast) {
                setTimeout(() => {
                    closeToast(id);
                }, 2000);
            }
        });
    });
</script>
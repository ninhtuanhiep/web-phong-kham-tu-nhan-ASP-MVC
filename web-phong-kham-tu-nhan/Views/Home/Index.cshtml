@section Scripts {
    <script>
        // ── HERO SLIDER ──
        let currentSlide = 0;
        const slides = document.querySelectorAll('.hero-slide');
        const dots   = document.querySelectorAll('.hero-dots .dot');
        let autoPlay;

        function goToSlide(index) {
            slides[currentSlide].classList.remove('active');
            dots[currentSlide].classList.remove('active');
            currentSlide = (index + slides.length) % slides.length;
            slides[currentSlide].classList.add('active');
            dots[currentSlide].classList.add('active');
        }

        function currentHeroSlide(index) {
            clearInterval(autoPlay);
            goToSlide(index);
            startAutoPlay();
        }

        function startAutoPlay() {
            autoPlay = setInterval(() => goToSlide(currentSlide + 1), 5000);
        }

        startAutoPlay();

        // ── COUNTER ANIMATION ──
        function animateCounter(el) {
            if (el.dataset.done) return;
            el.dataset.done = true;

            const target   = parseInt(el.dataset.target);
            const suffix   = el.dataset.suffix || '';
            const duration = 2000;
            const step     = target / (duration / 16);
            let current    = 0;

            const timer = setInterval(() => {
                current += step;
                if (current >= target) {
                    current = target;
                    clearInterval(timer);
                }
                el.textContent = target >= 1000
                    ? Math.floor(current).toLocaleString('vi-VN') + suffix
                    : Math.floor(current) + suffix;
            }, 16);
        }

        // ── SCROLL REVEAL ──
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry, i) => {
                if (!entry.isIntersecting) return;
                setTimeout(() => entry.target.classList.add('visible'), i * 100);
                revealObserver.unobserve(entry.target);
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.specialty-card, .doctor-card, .timeline-item, .testimonial-card, .stat-box')
            .forEach(el => {
                el.classList.add('reveal');
                revealObserver.observe(el);
            });

        // ── COUNTER TRIGGER ──
        const counterObserver = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (!e.isIntersecting) return;
                const num = e.target.querySelector('h3[data-target]');
                if (num) animateCounter(num);
                counterObserver.unobserve(e.target);
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('.stat-box').forEach(el => counterObserver.observe(el));
    </script>

    <script>
        $(document).ready(function () {
            $('.select2').select2({
                placeholder: "Vui lòng chọn chuyên khoa trước",
                allowClear: true,
                width: '100%'
            });

            $('.select1').select2({
                placeholder: "Tìm kiếm...",
                allowClear: true,
                width: '100%'
            });
        });


        // $(document).ready(function () {

        //     $('#chuyenKhoaSelect').change(function () {

        //         var specialtyId = $(this).val();

        //         if (specialtyId) {

        //             $.get('/BenhNhan/LichHen/GetDoctorsBySpecialty', { specialtyId: specialtyId }, function (data) {

        //                 var doctorSelect = $('#doctorSelect');

        //                 doctorSelect.empty();

        //                 doctorSelect.append('<option value="">--Chọn bác sĩ--</option>');

        //                 $.each(data, function (index, doctor) {
        //                     doctorSelect.append('<option value="' + doctor.id + '">' + doctor.fullName + '</option>');
        //                 });

        //                 doctorSelect.prop('disabled', false);

        //             });

        //         } else {

        //             $('#doctorSelect').prop('disabled', true);
        //         }
        //     });

        // });
        $(document).ready(function () {

            $('#chuyenKhoaSelect').change(function () {

            var specialtyId = $(this).val();
            var doctorSelect = $('#doctorSelect');

            if (specialtyId) {

                $.get('BenhNhan/LichHen/GetDoctorsBySpecialty', { specialtyId: specialtyId }, function (data) {

                    doctorSelect.empty();
                    doctorSelect.append('<option value="">--Chọn bác sĩ--</option>');

                    $.each(data, function (index, doctor) {
                        doctorSelect.append('<option value="' + doctor.id + '">' + doctor.fullName + '</option>');
                    });

                    doctorSelect.prop('disabled', false).trigger('change');
                });

            } else {
                // 🔥 RESET KHI CHỌN LẠI DEFAULT
                doctorSelect.empty();
                doctorSelect.append('<option value="">--Chọn bác sĩ--</option>');
                doctorSelect.prop('disabled', true).trigger('change');
            }
        });

    });
    </script>
}
@{
    ViewData["Title"] = "Home Page";
}
@* @model List<web_phong_kham_tu_nhan.Models.Entities.BacSi> *@
@model web_phong_kham_tu_nhan.Models.ViewModel.HomeViewModel
@{
    var chuyenKhoas = ViewBag.ChuyenKhoas as List<web_phong_kham_tu_nhan.Models.Entities.ChuyenKhoa>
                       ?? new List<web_phong_kham_tu_nhan.Models.Entities.ChuyenKhoa>();
}
<section class="hero">

    <!-- SLIDER BACKGROUND -->
    <div class="hero-slides">

        <div class="hero-slide active">
            <img src="/images/vitaly-gariev-ibZ2QiKkEsg-unsplash.jpg" alt="">
        </div>

        <div class="hero-slide">
            <img class="anh2" src="/images/erik-mclean--4JVGXz1x8g-unsplash.jpg" alt="">
        </div>

    </div>

    <!-- CONTENT -->
    <div class="container">

        <div class="row align-items-center g-5 hero-content">
            <!-- TEXT -->
            <div class="col-lg-6  text-white">
                <div class="title">
                    <h1 class="display-5 fw-bold mb-3">
                        Chăm sóc sức khỏe <br>
                        <span style="color:#B2F5EA;">chuyên nghiệp</span>
                    </h1>

                    <p class="lead mb-4" style="color:#E6FFFA;">
                        Đặt lịch khám nhanh chóng với đội ngũ bác sĩ chuyên môn cao
                        và hệ thống phòng khám hiện đại.
                    </p>
                </div>

                <br />
                <br />

                <div class="d-flex flex-wrap gap-3 datlich">

                    <a asp-area="BenhNhan"
                        asp-controller="LichHen"
                       asp-action="Create"
                       class="btn btn-lg px-4">

                        Đặt lịch khám

                    </a>

                    <a asp-controller="Home"
                       asp-action="About"
                       class="btn btn-lg px-4">

                        Tìm hiểu thêm

                    </a>

                </div>

            </div>
        </div>

    </div>

    <!-- DOT SLIDER -->
    <div class="hero-dots">

        <span class="dot active" onclick="currentHeroSlide(0)"></span>
        <span class="dot" onclick="currentHeroSlide(1)"></span>

    </div>

</section>

<section class="stats">

    <div class="container">

        <div class="row text-center">

            <div class="col-md-3">

                <div class="stat-box">

                    <div class="stat-icon">👨‍⚕️</div>

                    <h3 data-target="50">0+</h3>

                    <p>Bác sĩ</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <div class="stat-icon">🏥</div>

                    <h3 data-target="20">0</h3>

                    <p>Chuyên khoa</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <div class="stat-icon">👨‍👩‍👧‍👦</div>

                    <h3 data-target="10000" data-suffix="+">0</h3>

                    <p>Bệnh nhân</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <div class="stat-icon">⭐</div>

                    <h3>4.9</h3>

                    <p>Đánh giá</p>

                </div>

            </div>

        </div>

    </div>

</section>

<section class="specialties-section py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="section-title">
                Chuyên khoa nổi bật
            </h2>

            <p class="section-subtitle">
                Đội ngũ bác sĩ chuyên môn cao với nhiều chuyên khoa khác nhau
            </p>

        </div>

        <div class="row g-4">

            <div class="col-lg-4 col-md-6">

                <div class="specialty-card">

                    <div class="icon-box">
                        <i class="bi bi-heart-pulse"></i>
                    </div>

                    <h5>Tim mạch</h5>

                    <p>
                        Khám và điều trị các bệnh lý về tim mạch với thiết bị hiện đại.
                    </p>

                </div>

            </div>


            <div class="col-lg-4 col-md-6">

                <div class="specialty-card">

                    <div class="icon-box">
                        <i class="bi bi-emoji-smile"></i>
                    </div>

                    <h5>Nhi khoa</h5>

                    <p>
                        Chăm sóc sức khỏe toàn diện cho trẻ em.
                    </p>

                </div>

            </div>


            <div class="col-lg-4 col-md-6">

                <div class="specialty-card">

                    <div class="icon-box">
                        <i class="bi bi-bandaid"></i>
                    </div>

                    <h5>Da liễu</h5>

                    <p>
                        Điều trị các vấn đề về da với phương pháp tiên tiến.
                    </p>

                </div>

            </div>


            <div class="col-lg-4 col-md-6">

                <div class="specialty-card">

                    <div class="icon-box">
                        <i class="bi bi-ear"></i>
                    </div>

                    <h5>Tai Mũi Họng</h5>

                    <p>
                        Khám và điều trị các bệnh tai mũi họng hiệu quả.
                    </p>

                </div>

            </div>


            <div class="col-lg-4 col-md-6">

                <div class="specialty-card">

                    <div class="icon-box">
                        <i class="bi bi-person-walking"></i>
                    </div>

                    <h5>Xương khớp</h5>

                    <p>
                        Điều trị đau nhức và các bệnh lý về xương khớp.
                    </p>

                </div>

            </div>


            <div class="col-lg-4 col-md-6">

                <div class="specialty-card">

                    <div class="icon-box">
                        <i class="bi bi-hospital"></i>
                    </div>

                    <h5>Nội tổng quát</h5>

                    <p>
                        Khám sức khỏe tổng quát và điều trị nhiều bệnh lý khác nhau.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>
<section class="doctor-section py-5">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="section-title">Đội ngũ bác sĩ</h2>
            <p class="section-subtitle">
                Các bác sĩ giàu kinh nghiệm, tận tâm với bệnh nhân
            </p>
        </div>

        <div class="row g-4">

            @foreach (var item in Model.Doctors.Take(3))
            {
                <div class="col-lg-4 col-md-6">
                    <div class="doctor-card">

                        <img src="@(item.ImageUrl ?? "/Images/default-avatar.png")" class="doctor-img" />

                        <div class="doctor-body">
                            <h5>@item.FullName</h5>

                            <span class="specialty">
                                @item.ChuyenKhoa?.Name
                            </span>

                            <p>
                                @item.tieuSu
                            </p>

                            <a
                               asp-controller="LichHen"
                               asp-action="Create"
                               asp-route-doctorId="@item.Id"
                               class="btn btn-primary w-100">
                                Book Appointment
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>

        @if(Model.Doctors.Count() > 3)
        {
            <!-- Nút View All -->
            <div class="text-center mt-5">
                <a asp-controller="Doctor"
                   asp-action="Index"
                   class="btn btn-outline-primary px-4">
                    View All Doctors
                </a>
            </div>
        }
    </div>

</section>

<section class="timeline-section py-5">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold">Quy trình khám bệnh</h2>
            <p class="text-muted">Nhanh chóng - Đơn giản - Hiệu quả</p>
        </div>

        <div class="timeline">

            <!-- STEP 1 -->
            <div class="timeline-item left">
                <div class="timeline-icon bg-primary">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <div class="timeline-content shadow-sm">
                    <h5>Đặt lịch khám</h5>
                    <p>Chọn bác sĩ và thời gian phù hợp chỉ trong vài giây.</p>
                </div>
            </div>

            <!-- STEP 2 -->
            <div class="timeline-item right">
                <div class="timeline-icon bg-success">
                    <i class="bi bi-person-check"></i>
                </div>
                <div class="timeline-content shadow-sm">
                    <h5>Xác nhận lịch</h5>
                    <p>Hệ thống xác nhận nhanh chóng qua email hoặc điện thoại.</p>
                </div>
            </div>

            <!-- STEP 3 -->
            <div class="timeline-item left">
                <div class="timeline-icon bg-warning">
                    <i class="bi bi-hospital"></i>
                </div>
                <div class="timeline-content shadow-sm">
                    <h5>Đến khám</h5>
                    <p>Được hướng dẫn tận tình khi đến phòng khám.</p>
                </div>
            </div>

            <!-- STEP 4 -->
            <div class="timeline-item right">
                <div class="timeline-icon bg-danger">
                    <i class="bi bi-clipboard2-pulse"></i>
                </div>
                <div class="timeline-content shadow-sm">
                    <h5>Nhận kết quả</h5>
                    <p>Xem kết quả và nhận tư vấn từ bác sĩ chuyên môn cao.</p>
                </div>
            </div>


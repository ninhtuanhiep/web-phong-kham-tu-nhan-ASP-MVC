@model List<web_phong_kham_tu_nhan.Models.Entities.BacSi>

@* 
PSEUDOCODE / PLAN:
- Read ViewBag.ChuyenKhoas into a local variable.
- If ViewBag.ChuyenKhoas is null, replace it with an empty List<ChuyenKhoa> to avoid null dereference warnings.
- Render tabs: a default "all" tab and one tab per ChuyenKhoa in the list.
- Render the doctor list unchanged.
- Keep existing client-side filtering script and styles.
*@

@{
    var chuyenKhoas = ViewBag.ChuyenKhoas as List<web_phong_kham_tu_nhan.Models.Entities.ChuyenKhoa>
                       ?? new List<web_phong_kham_tu_nhan.Models.Entities.ChuyenKhoa>();
}

<div class="container py-5">

    <!-- TITLE -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">Đội Ngũ Bác Sĩ</h2>
        <p class="text-muted">Chuyên nghiệp - Tận tâm - Giàu kinh nghiệm</p>
    </div>

    <!-- TABS CHUYÊN KHOA -->
    <ul class="nav nav-pills justify-content-center mb-4" id="doctorTabs">
        <li class="nav-item">
            <button class="nav-link active" data-bs-target="all">Tất cả</button>
        </li>

        @foreach (var ck in chuyenKhoas)
        {
            <li class="nav-item">
                <button class="nav-link" data-bs-target="@ck.Id">
                    @ck.Name (@Model.Count(X => X.ChuyenKhoaId == ck.Id))
                </button>
            </li>
        }
    </ul>

    <!-- DOCTOR LIST -->
    <div class="row" id="doctorList">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4 doctor-item" data-khoa="@item.ChuyenKhoaId">

                <div class="card doctor-card shadow-sm h-100 text-center">

                    <div class="doctor-img">
                        <img src="@(item.ImageUrl ?? "/Images/default-avatar.png")" alt="@item.FullName" />
                    </div>

                    <div class="card-body">
                        <h5 class="fw-bold">@item.FullName</h5>
                        <p class="text-muted">@item.ChuyenKhoa?.Name</p>
                    </div>

                    <p>
                        @item.tieuSu
                    </p>

                </div>

            </div>
        }

    </div>
</div>

<!-- STYLE -->
<style>
    .doctor-card {
        border: none;
        border-radius: 15px;
        transition: 0.3s;
    }

        .doctor-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

    .doctor-img {
        width: 100%;
        height: 450px;
        overflow: hidden;
        border-radius: 15px 15px 0 0;
    }

        .doctor-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .nav-pills .nav-link {
        margin: 5px;
        border-radius: 20px;
        padding: 8px 18px;
        cursor: pointer;
    }

        .nav-pills .nav-link.active {
            background-color: #0d6efd;
        }
</style>

<!-- SCRIPT FILTER -->
<script>
    document.querySelectorAll("#doctorTabs .nav-link").forEach(btn => {
        btn.addEventListener("click", function () {

            document.querySelectorAll("#doctorTabs .nav-link")
                .forEach(b => b.classList.remove("active"));

            this.classList.add("active");

            let khoa = this.getAttribute("data-bs-target");

            document.querySelectorAll(".doctor-item").forEach(item => {

                if (khoa === "all" || item.dataset.khoa === khoa) {
                    item.style.display = "block";
                } else {
                    item.style.display = "none";
                }

            });
        });
    });
</script>
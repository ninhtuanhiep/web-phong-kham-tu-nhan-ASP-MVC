<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" charset="utf-8"/>
    <title>Bảng quản trị</title>
    <link rel="stylesheet" href="~/css/Admin/admin.css" />
    <link rel="stylesheet" href="~/css/Admin/dashboard.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
</head>
<body>
    <div class="admin-wrapper">
        @{  
            var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        }
        @*SideBar*@
        <div class="sidebar">
            <h3 class="logo" style="margin-bottom:40px;">BẢNG QUẢN TRỊ</h3>
            <ul>
                <li class="@(controller == "DashBoard" ? "active" : "")"><a asp-area="Admin" asp-controller="DashBoard" asp-action="Index">DashBoard</a></li>
                <li class="@(controller == "ChuyenKhoa" ? "active" : "")"><a asp-area="Admin" asp-controller="ChuyenKhoa" asp-action="Index" style="padding-right:90px;">Chuyên Khoa</a></li>
                <li class="@(controller == "BacSi" ? "active" : "")"><a asp-area="Admin" asp-controller="BacSi" asp-action="Index" style="padding-right:145px;">Bác Sĩ</a></li>
                <li class="@(controller == "BenhNhan" ? "active" : "")"><a asp-area="Admin" asp-controller="BenhNhan" asp-action="Index" style="padding-right:100px;">Bệnh Nhân</a></li>
                <li class="@(controller == "LichLamViecBacSi" ? "active" : "")"><a asp-area="Admin" asp-controller="LichLamViecBacSi" asp-action="Index">Lịch Làm Việc Của Bác Sĩ</a></li>
                <li class="@(controller == "LichHen" ? "active" : "")"><a asp-area="Admin" asp-controller="LichHen" asp-action="Index" style="padding-right:100px;">Lịch Hẹn</a></li>
                <li class="@(controller == "User" ? "active" : "")"><a asp-area="Admin" asp-controller="User" asp-action="Index" style="padding-right:100px;">Người dùng</a></li>
            </ul>
        </div>


        @*Content*@
        <div class="content-area">
            @RenderBody()
        </div>
        @if (TempData["success"] != null)
        {
            <div class="toast-success" id="toastMessage">
                @TempData["success"]
            </div>
        }
    </div>

    <script src="~/js/admin.js"></script>
</body>
</html>
